# FastAPI
FASTAPI_SECRET_KEY=                  # Random 32-byte hex: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_EMAILS=                        # Comma-separated admins: always allowed to edit + manage the allowlist
ALLOWED_EMAILS=                      # Extra comma-separated emails allowed to edit (reading is always public)

# Supabase (the recipes project — separate from budget)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=                   # Public anon key
SUPABASE_SERVICE_ROLE_KEY=           # Service role key — backend only, never sent to the browser

# Optional error monitoring
SENTRY_DSN=

# Render sets PORT automatically; override locally as needed
PORT=8000

# Environment flag — "true" on Render, "false" locally
IS_PRODUCTION=false
